# Copy this file to .env before running
# PowerShell: Copy-Item .env.example .env

# Required (use a long random key for real deployment)
SECRET_KEY=django-insecure-change-this-before-deploy

# Local development
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Optional: if empty, project uses default BASE_DIR/database/db.sqlite3
# For absolute path on Windows use: D:\File Code\Fashion Website\database\db.sqlite3
DB_PATH=

# Optional security flags (recommended when DEBUG=False / deploy)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
